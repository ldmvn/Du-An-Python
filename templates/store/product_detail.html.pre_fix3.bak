{% extends 'store/base.html' %}
{% load static humanize %}

{% block title %}{{ product.name }} - MOBILE STORE{% endblock %}

{% block extra_css %}
<link rel="stylesheet" href="{% static 'css/store-pages.css' %}">
<style>
.pd-shell {
    font-family: "Times New Roman", Times, serif;
}

.pd-spec-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 1200;
    background: rgba(15, 23, 42, 0.55);
    display: none;
    align-items: center;
    justify-content: center;
    padding: 20px;
}

.pd-spec-modal-overlay.is-open {
    display: flex;
}

.pd-spec-modal {
    width: min(980px, 100%);
    max-height: min(88vh, 780px);
    background: #f3f4f6;
    border-radius: 16px;
    box-shadow: 0 20px 48px rgba(15, 23, 42, 0.28);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    font-family: "Times New Roman", Times, serif;
}

.pd-spec-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 22px;
    background: #ffffff;
    border-bottom: 1px solid #e5e7eb;
}

.pd-spec-modal-header h3 {
    margin: 0;
    font-size: 30px;
    line-height: 1.1;
    color: #111827;
}

.pd-spec-modal-close {
    border: 0;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: #e5e7eb;
    color: #111827;
    font-size: 24px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

.pd-spec-modal-tabs {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    white-space: nowrap;
    background: #ffffff;
    border-bottom: 1px solid #e5e7eb;
    padding: 0 14px;
}

.pd-spec-tab-btn {
    border: 0;
    background: transparent;
    color: #4b5563;
    font-size: 24px;
    line-height: 1.2;
    padding: 14px 10px 13px;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    flex: 0 0 auto;
}

.pd-spec-tab-btn.is-active {
    color: #dc2626;
    border-bottom-color: #dc2626;
    font-weight: 700;
}

.pd-spec-modal-body {
    padding: 18px;
    overflow-y: auto;
}

.pd-spec-modal-section-title {
    margin: 0 0 12px;
    color: #1f2937;
    font-size: 30px;
}

.pd-spec-modal-section {
    margin-bottom: 22px;
    scroll-margin-top: 10px;
}

.pd-spec-modal-section:last-child {
    margin-bottom: 0;
}

.pd-spec-modal-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    background: #ffffff;
    border: 1px solid #d1d5db;
    border-radius: 10px;
    overflow: hidden;
}

.pd-spec-modal-table th,
.pd-spec-modal-table td {
    padding: 12px 14px;
    border-bottom: 1px solid #e5e7eb;
}

.pd-spec-modal-table tr:last-child th,
.pd-spec-modal-table tr:last-child td {
    border-bottom: 0;
}

.pd-spec-modal-table th {
    width: 34%;
    text-align: left;
    color: #2563eb;
    background: #f8fafc;
    font-weight: 600;
}

.pd-spec-empty {
    margin: 0;
    padding: 28px 0;
    text-align: center;
    color: #6b7280;
    font-size: 24px;
}

@media (max-width: 768px) {
    .pd-spec-modal-overlay {
        padding: 0;
    }

    .pd-spec-modal {
        width: 100%;
        height: 100%;
        max-height: 100vh;
        border-radius: 0;
    }

    .pd-spec-modal-header h3 {
        font-size: 24px;
    }

    .pd-spec-tab-btn {
        font-size: 17px;
        padding: 12px 8px;
    }

    .pd-spec-modal-section-title {
        font-size: 22px;
    }

    .pd-spec-modal-table th,
    .pd-spec-modal-table td {
        padding: 10px 12px;
        font-size: 15px;
    }

    .pd-spec-empty {
        font-size: 16px;
    }
}
</style>
{% endblock %}

{% block content %}
<div class="pd-shell">
    <div class="pd-container">
        <nav class="pd-breadcrumb" aria-label="breadcrumb">
            <a href="{% url 'store:home' %}">Trang chá»§</a>
            <span>/</span>
            {% if product.category %}
            <a href="{% url 'store:home' %}?brand={{ product.category.name|urlencode }}">{{ product.category.name }}</a>
            <span>/</span>
            {% endif %}
            <span>{{ product.name }}</span>
        </nav>

        <header class="pd-headline">
            <div class="pd-title-wrap">
                <h1>{{ product.name }}</h1>
                <div class="pd-meta-row">
                    <div class="pd-score">
                        <span class="pd-star">★</span>
                        <strong>{{ review_summary.avg|default:0 }}</strong>
                        <span>({{ review_summary.count }} đánh giá)</span>
                    </div>
                    <div class="pd-shortcuts">
                        <button type="button" class="pd-ghost-btn btn-wishlist" data-product-id="{{ product.id }}">Yêu thích</button>
                        <a href="#pd-specs" class="pd-ghost-btn">Thông số</a>
                        <a href="#pd-reviews" class="pd-ghost-btn">ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¾ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚ÂÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¡nh giÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¡</a>
                        <a href="#pd-related" class="pd-ghost-btn">So sánh</a>
                    </div>
                </div>
            </div>
        </header>

        <section class="pd-main-grid">
            <div class="pd-gallery-col">
                <div class="pd-gallery-panel">
                    <!-- Main Media Display (Video Featured) -->
                    <div class="pd-stage" id="pdStage">
                        <div class="pd-zoom-lens" id="pdZoomLens"></div>
                        {% if primary_media %}
                            {% if primary_media.media_type == 'video' %}
                            <video id="pdMainVideo" class="pd-main-media" controls autoplay muted playsinline poster="{{ product.image.url|default:'' }}">
                                <source src="{{ primary_media.url }}">
                            </video>
                            <img id="pdMainImage" class="pd-main-media pd-hidden" alt="{{ product.name }}">
                            {% else %}
                            <img id="pdMainImage" class="pd-main-media" src="{{ primary_media.url }}" alt="{{ product.name }}">
                            <video id="pdMainVideo" class="pd-main-media pd-hidden" controls autoplay muted playsinline poster="{{ product.image.url|default:'' }}">
                                <source src="">
                            </video>
                            {% endif %}
                        {% else %}
                        <div class="pd-media-empty">Chưa có ảnh hoặc video</div>
                        <img id="pdMainImage" class="pd-main-media pd-hidden" alt="{{ product.name }}">
                        <video id="pdMainVideo" class="pd-main-media pd-hidden" controls autoplay muted playsinline></video>
                        {% endif %}

                        {% if feature_image_url or feature_points %}
                        <div id="pdFeaturePanel" class="pd-feature-panel pd-hidden">
                            {% if feature_image_url %}
                            <div class="pd-feature-media">
                                <img src="{{ feature_image_url }}" alt="{{ product.name }}">
                            </div>
                            {% endif %}
                            <div class="pd-feature-copy">
                                <h3>TINH NANG NOI BAT</h3>
                                {% if feature_points %}
                                <ul>
                                    {% for point in feature_points %}
                                    <li>{{ point }}</li>
                                    {% endfor %}
                                </ul>
                                {% endif %}
                            </div>
                        </div>
                        {% endif %}
                        
                        <!-- Navigation Buttons -->
                        {% if media_gallery|length > 1 %}
                        <button id="pdPrevBtn" class="pd-nav-btn pd-nav-prev" title="Ảnh trước">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="15 18 9 12 15 6"></polyline>
                            </svg>
                        </button>
                        <button id="pdNextBtn" class="pd-nav-btn pd-nav-next" title="áº¢nh tiáº¿p theo">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="9 18 15 12 9 6"></polyline>
                            </svg>
                        </button>
                        {% endif %}
                    </div>

                    <!-- Video Gallery Section -->
                    {% if media_gallery %}
                        {% with videos=media_gallery|dictsort:"is_image" %}
                            {% with video_items=videos|slice:":10" %}
                                {% if video_items %}
                                <div class="pd-media-section">
                                    <h4 class="pd-media-section-title">Video</h4>
                                    <div class="pd-video-gallery" id="pdVideoGallery">
                                        {% for media in media_gallery %}
                                            {% if media.media_type == 'video' %}
                                            <button
                                                type="button"
                                                class="pd-video-thumb {% if media.is_primary %}is-active{% endif %}"
                                                data-media-type="video"
                                                data-url="{{ media.url }}"
                                                aria-label="{{ media.title }}"
                                            >
                                                <video muted playsinline>
                                                    <source src="{{ media.url }}">
                                                </video>
                                                <span class="pd-thumb-badge">Phát</span>
                                            </button>
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                </div>
                                {% endif %}
                            {% endwith %}
                        {% endwith %}

                        <!-- Image Gallery Section -->
                        <div class="pd-media-section">
                            <div class="pd-image-gallery" id="pdImageGallery">
                                <!-- Video Button - Show first video if exists -->
                                {% if first_video %}
                                    <button
                                        type="button"
                                        class="pd-media-selector-btn {% if primary_media and primary_media.media_type == 'video' %}is-active{% endif %}"
                                        data-media-type="video"
                                        data-url="{{ first_video.url }}"
                                        aria-label="Video"
                                        title="Video"
                                    >
                                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <polygon points="23 7 16 12 23 17 23 7"></polygon>
                                            <rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect>
                                        </svg>
                                        <span class="pd-media-label">Video</span>
                                    </button>
                                {% endif %}

                                <!-- Features Button -->
                                {% if feature_image_url or feature_points %}
                                <button
                                    type="button"
                                    class="pd-feature-selector-btn"
                                    id="pdFeaturesBtn"
                                    data-media-type="feature"
                                    data-url=""
                                    aria-label="Tính năng nổi bật"
                                    title="Tính năng nổi bật"
                                >
                                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                                    </svg>
                                    <span class="pd-media-label">Tính năng</span>
                                </button>
                                {% endif %}
                                
                                {% for media in media_gallery %}
                                    {% if media.media_type == 'image' %}
                                        <button
                                            type="button"
                                            class="pd-image-thumb {% if media.is_primary %}is-active{% endif %}"
                                            data-media-type="image"
                                            data-url="{{ media.url }}"
                                            aria-label="{{ media.title }}"
                                        >
                                            <img src="{{ media.url }}" alt="{{ media.title }}">
                                        </button>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}

                    <aside class="pd-spec-card pd-spec-card-left" id="pd-specs">
                        <div class="pd-spec-header">
                            <h2>Thông số kỹ thuật</h2>
                            <button type="button" class="pd-spec-more" id="specToggleBtn">Xem táº¥t cáº£</button>
                        </div>
                        <div class="pd-spec-list pd-spec-list-collapsed" id="specList">
                            {% for spec in specifications %}
                            <div class="pd-spec-row {% if forloop.counter > 6 %}pd-spec-extra{% endif %}">
                                <span>{{ spec.key }}</span>
                                <strong>{{ spec.value }}</strong>
                            </div>
                            {% endfor %}
                        </div>
                    </aside>
                </div>
            </div>

            <div class="pd-info-col">
                <div class="pd-info-panel">
                    <div class="pd-buy-box">
                        <div class="pd-price-card">
                            <div class="pd-price-top">
                                <div class="pd-price-stack">
                                    <div class="pd-sale-price" id="current-price">{{ base_price|intcomma }}Ä‘</div>
                                    <div class="pd-old-line">
                                        {% if product.discount > 0 %}
                                        <span class="pd-old-price" id="old-price">{{ product.price|intcomma }}Ä‘</span>
                                        <span class="pd-discount-pill">-{{ product.discount }}%</span>
                                        {% endif %}
                                    </div>
                                </div>
                                <div class="pd-tradein">
                                    <span>Thu cÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¦ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â© lÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Âªn ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¾ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¹Ã…â€œÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â»ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Âi</span>
                                    <strong id="tradein-price">{{ base_price|add:"-500000"|intcomma }}Ä‘</strong>
                                </div>
                            </div>
                            <div class="pd-promo-line">GiÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¡ ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¾ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¹Ã…â€œÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â£ gÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â»ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã¢â‚¬Å“m ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â°u ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¾ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¹Ã…â€œÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â£i online. CÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â³ hÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â»ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â trÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â»ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â£ thu cÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¦ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â©, trÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚ÂºÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â£ gÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â³p vÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â  giao nhanh trong ngÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â y.</div>
                        </div>

                        <div class="pd-option-block">
                            <div class="pd-option-head">
                                <h3>Dung lượng</h3>
                            </div>
                            <div class="pd-variant-grid" id="storage-options">
                                {% for option in storage_options %}
                                <button
                                    type="button"
                                    class="pd-option-card {% if forloop.first %}is-active{% endif %}"
                                    data-price="{{ option.price }}"
                                    data-capacity="{{ option.capacity }}"
                                >
                                    <span class="pd-option-main">{{ option.capacity }}</span>
                                    <small>{{ option.label }}</small>
                                </button>
                                {% endfor %}
                            </div>
                        </div>

                        <div class="pd-option-block">
                            <div class="pd-option-head">
                                <h3>Màu sắc</h3>
                                <div class="pd-selected-copy" id="selectedColorLabel">{{ color_options.0.name }}</div>
                            </div>
                            <div class="pd-color-grid" id="color-options">
                                {% for color in color_options %}
                                <button
                                    type="button"
                                    class="pd-color-card {% if forloop.first %}is-active{% endif %}"
                                    data-color-name="{{ color.name }}"
                                    data-color-price="{{ color.price_delta }}"
                                >
                                    <span class="pd-color-swatch" data-color="{{ color.hex }}"></span>
                                    <span class="pd-color-copy">
                                        <strong>{{ color.name }}</strong>
                                        {% if color.price_delta %}
                                        <small>+{{ color.price_delta|intcomma }}Ä‘</small>
                                        {% else %}
                                        <small>Giá chuẩn</small>
                                        {% endif %}
                                    </span>
                                </button>
                                {% endfor %}
                            </div>
                        </div>

                        <div class="pd-actions">
                            <button type="button" class="pd-buy-btn btn-buy-now" data-product-id="{{ product.id }}">Mua ngay</button>
                            <button type="button" class="pd-cart-btn btn-add-cart" data-product-id="{{ product.id }}">ThÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Âªm vÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â o giÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â»ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â hÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â ng</button>
                            <button type="button" class="pd-installment-btn">Trả góp 0%</button>
                        </div>

                        <div class="pd-promo-box">
                            <div class="pd-promo-title">Khuyến mãi đi kèm</div>
                            <div class="pd-promo-list">
                                {% for promo in promotions %}
                                <div class="pd-promo-item">
                                    <span class="pd-promo-icon">{{ promo.icon|slice:":1"|upper }}</span>
                                    <span>{{ promo.text }}</span>
                                </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>

                    <div class="pd-detail-stack">
                        <section class="pd-reviews-card" id="pd-reviews">
                            <div class="pd-review-summary">
                                <div>
                                    <h2>ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¾ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚ÂÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¡nh giÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¡ & bÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬nh luÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚ÂºÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â­n</h2>
                                    <div class="pd-review-score-big">{{ review_summary.avg|default:0 }}/5</div>
                                    <div class="pd-review-stars-line">
                                        {% for _ in "12345" %}
                                        <span>★</span>
                                        {% endfor %}
                                        <span class="pd-review-count">({{ review_summary.count }} đánh giá)</span>
                                    </div>
                                </div>
                            </div>

                            <form method="POST" class="pd-review-form">
                                {% csrf_token %}
                                <div class="pd-rating-picker">
                                    <span>ChÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â»ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Ân sÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â»ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¹Ã…â€œ sao</span>
                                    <div class="pd-rating-buttons">
                                        {% for star in review_summary.stars %}
                                        <label class="pd-rate-chip">
                                            <input type="radio" name="rating" value="{{ star }}" {% if selected_review and selected_review.rating == star %}checked{% endif %} {% if not selected_review and star == 5 %}checked{% endif %}>
                                            <span>{{ star }} ★</span>
                                        </label>
                                        {% endfor %}
                                    </div>
                                </div>
                                <textarea name="comment" rows="4" class="pd-review-textarea" placeholder="Chia sÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚ÂºÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â» cÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚ÂºÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â£m nhÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚ÂºÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â­n thÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â»ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â±c tÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚ÂºÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¿ vÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â»ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â sÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚ÂºÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â£n phÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚ÂºÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â©m...">{% if selected_review %}{{ selected_review.comment }}{% endif %}</textarea>
                                <button type="submit" class="pd-review-submit">Gửi đánh giá</button>
                            </form>

                            <div class="pd-comment-list">
                                {% for review in reviews %}
                                <article class="pd-comment-item">
                                    <div class="pd-comment-top">
                                        <strong>{{ review.user.username }}</strong>
                                        <div class="pd-comment-stars">
                                            {% for _ in "12345"|slice:":" %}
                                            {% if forloop.counter <= review.rating %}
                                            <span class="is-filled">★</span>
                                            {% else %}
                                            <span>★</span>
                                            {% endif %}
                                            {% endfor %}
                                        </div>
                                    </div>
                                    <div class="pd-comment-date">{{ review.created_at|date:"d/m/Y H:i" }}</div>
                                    <p>{{ review.comment|default:"Khách hàng chưa để lại bình luận chi tiết." }}</p>
                                </article>
                                {% empty %}
                                <div class="pd-empty-comment">Chưa có đánh giá nào cho sản phẩm này.</div>
                                {% endfor %}
                            </div>
                        </section>

                    </div>
                </div>
            </div>
        </section>

        {% if related_products %}
        <section class="pd-related" id="pd-related">
            <div class="pd-section-head">
                <h2>Sản phẩm liên quan</h2>
                <div class="pd-slider-actions">
                    <button type="button" class="pd-slider-btn" id="relatedPrevBtn">‹</button>
                    <button type="button" class="pd-slider-btn" id="relatedNextBtn">›</button>
                </div>
            </div>
            <div class="pd-related-track" id="pdRelatedTrack">
                {% for p in related_products %}
                <a href="{% url 'store:product_detail' p.id %}" class="pd-related-card">
                    <div class="pd-related-media">
                        {% if p.image %}
                        <img src="{{ p.image.url }}" alt="{{ p.name }}">
                        {% else %}
                        <div class="pd-media-empty">No image</div>
                        {% endif %}
                    </div>
                    <div class="pd-related-body">
                        <h3>{{ p.name }}</h3>
                        <div class="pd-related-price">{{ p.get_discounted_price|intcomma }}Ä‘</div>
                        <div class="pd-related-sub">{{ p.ram }} / {{ p.rom }}</div>
                    </div>
                </a>
                {% endfor %}
            </div>
        </section>
        {% endif %}
    </div>
</div>

{{ storage_options|json_script:"product-storage-data" }}
{{ color_options|json_script:"product-color-data" }}
{{ specifications|json_script:"product-spec-data" }}

<div class="pd-spec-modal-overlay" id="pdSpecModal" aria-hidden="true">
    <div class="pd-spec-modal" role="dialog" aria-modal="true" aria-labelledby="pdSpecModalTitle">
        <div class="pd-spec-modal-header">
            <h3 id="pdSpecModalTitle">Thông số kỹ thuật</h3>
            <button type="button" class="pd-spec-modal-close" id="pdSpecModalClose" aria-label="Đóng">&times;</button>
        </div>
        <div class="pd-spec-modal-tabs" id="pdSpecModalTabs"></div>
        <div class="pd-spec-modal-body" id="pdSpecModalContent"></div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const storageData = JSON.parse(document.getElementById('product-storage-data').textContent);
    const colorData = JSON.parse(document.getElementById('product-color-data').textContent);
    const specData = JSON.parse(document.getElementById('product-spec-data').textContent);
    
    // Handle both old and new gallery selectors
    const thumbButtons = document.querySelectorAll('.pd-video-thumb, .pd-image-thumb, .pd-media-selector-btn, .pd-feature-selector-btn, #pdThumbStrip .pd-thumb');
    const mainImage = document.getElementById('pdMainImage');
    const mainVideo = document.getElementById('pdMainVideo');
    const featurePanel = document.getElementById('pdFeaturePanel');
    const stage = document.getElementById('pdStage');
    const currentPrice = document.getElementById('current-price');
    const tradeinPrice = document.getElementById('tradein-price');
    const selectedColorLabel = document.getElementById('selectedColorLabel');
    const storageButtons = document.querySelectorAll('#storage-options .pd-option-card');
    const colorButtons = document.querySelectorAll('#color-options .pd-color-card');
    const specToggleBtn = document.getElementById('specToggleBtn');
    const specModal = document.getElementById('pdSpecModal');
    const specModalClose = document.getElementById('pdSpecModalClose');
    const specModalTabs = document.getElementById('pdSpecModalTabs');
    const specModalContent = document.getElementById('pdSpecModalContent');
    const relatedTrack = document.getElementById('pdRelatedTrack');
    const relatedPrevBtn = document.getElementById('relatedPrevBtn');
    const relatedNextBtn = document.getElementById('relatedNextBtn');

    const state = {
        basePrice: storageData[0] ? Number(storageData[0].price) : 0,
        colorDelta: colorData[0] ? Number(colorData[0].price_delta) : 0
    };

    function formatPrice(value) {
        return new Intl.NumberFormat('vi-VN').format(value) + 'Ä‘';
    }

    function renderPrice() {
        const total = state.basePrice + state.colorDelta;
        if (currentPrice) currentPrice.textContent = formatPrice(total);
        if (tradeinPrice) tradeinPrice.textContent = formatPrice(Math.max(total - 500000, 0));
    }

    const specCategories = [
        'Màn hình',
        'Camera sau',
        'Camera trước',
        'Vi xá»­ lÃ½ & Ä‘á»“ há»a',
        'Giao tiáº¿p & káº¿t ná»‘i',
        'RAM & lưu trữ',
        'Tính năng khác',
        'Bá»™ xá»­ lÃ½ & Äá»“ há»a',
        'KÃ­ch thÆ°á»›c & Trá»ng lÆ°á»£ng',
        'Thông số khác',
        'Pin & công nghệ sạc',
        'Tiện ích khác',
        'Cá»•ng káº¿t ná»‘i',
        'Thông tin chung'
    ];
    const groupedSpecs = {};
    let activeSpecCategory = specCategories[0];
    let isProgrammaticSpecScroll = false;

    specCategories.forEach(function (category) {
        groupedSpecs[category] = [];
    });

    function normalizeSpecText(input) {
        return String(input || '')
            .normalize('NFD')
            .replace(/[\u0300-\u036f]/g, '')
            .toLowerCase();
    }

    function escapeHtml(input) {
        return String(input || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function resolveCategoryByKey(specKey) {
        const key = normalizeSpecText(specKey);

        if (key.includes('man hinh') || key.includes('display')) return 'Màn hình';
        if (key.includes('camera truoc') || key.includes('selfie')) return 'Camera trước';
        if (key.includes('camera sau') || key.includes('camera chinh')) return 'Camera sau';
        if (key.includes('bo xu ly') || key.includes('processor')) return 'Bá»™ xá»­ lÃ½ & Äá»“ há»a';
        if (key.includes('chip') || key.includes('cpu') || key.includes('gpu') || key.includes('do hoa')) return 'Vi xá»­ lÃ½ & Ä‘á»“ há»a';
        if (key.includes('ram') || key.includes('rom') || key.includes('luu tru') || key.includes('bo nho')) return 'RAM & lưu trữ';
        if (key.includes('pin') || key.includes('sac') || key.includes('mah') || key.includes('w')) return 'Pin & công nghệ sạc';
        if (key.includes('cong ket noi') || key.includes('usb') || key.includes('type-c') || key.includes('jack')) return 'Cá»•ng káº¿t ná»‘i';
        if (key.includes('giao tiep') || key.includes('ket noi') || key.includes('wifi') || key.includes('bluetooth') || key.includes('nfc') || key.includes('mang')) return 'Giao tiáº¿p & káº¿t ná»‘i';
        if (key.includes('kich thuoc') || key.includes('trong luong') || key.includes('do day')) return 'KÃ­ch thÆ°á»›c & Trá»ng lÆ°á»£ng';
        if (key.includes('tien ich')) return 'Tiện ích khác';
        if (key.includes('tinh nang') || key.includes('bao mat') || key.includes('khang nuoc') || key.includes('cam bien')) return 'Tính năng khác';
        if (key.includes('thong tin chung') || key.includes('he dieu hanh') || key.includes('xuat xu')) return 'Thông tin chung';
        return 'Thông số khác';
    }

    (specData || []).forEach(function (spec) {
        const category = resolveCategoryByKey(spec.key);
        groupedSpecs[category].push(spec);
    });

    function updateSpecTabActiveState() {
        if (!specModalTabs) return;
        specModalTabs.querySelectorAll('.pd-spec-tab-btn').forEach(function (button) {
            button.classList.toggle('is-active', button.dataset.specCategory === activeSpecCategory);
        });
    }

    function renderSpecModalContent() {
        if (!specModalContent) return;

        const sectionsHtml = specCategories.map(function (category, index) {
            const categorySpecs = groupedSpecs[category] || [];
            const safeCategory = escapeHtml(category);
            const sectionId = 'pd-spec-section-' + index;

            if (categorySpecs.length === 0) {
                return '<section class="pd-spec-modal-section" id="' + sectionId + '" data-spec-section="' + safeCategory + '"><h4 class="pd-spec-modal-section-title">' + safeCategory + '</h4><p class="pd-spec-empty">Chua co thong tin cho muc nay.</p></section>';
            }

            const rows = categorySpecs.map(function (spec) {
                return '<tr><th>' + escapeHtml(spec.key) + '</th><td>' + escapeHtml(spec.value) + '</td></tr>';
            }).join('');
            return '<section class="pd-spec-modal-section" id="' + sectionId + '" data-spec-section="' + safeCategory + '"><h4 class="pd-spec-modal-section-title">' + safeCategory + '</h4><table class="pd-spec-modal-table"><tbody>' + rows + '</tbody></table></section>';
        }).join('');

        specModalContent.innerHTML = sectionsHtml;
    }

    function renderSpecModalTabs() {
        if (!specModalTabs) return;
        const tabsHtml = specCategories.map(function (category, index) {
            const activeClass = category === activeSpecCategory ? 'is-active' : '';
            const safeCategory = escapeHtml(category);
            return '<button type="button" class="pd-spec-tab-btn ' + activeClass + '" data-spec-category="' + safeCategory + '" data-spec-target="pd-spec-section-' + index + '">' + safeCategory + '</button>';
        }).join('');
        specModalTabs.innerHTML = tabsHtml;

        specModalTabs.querySelectorAll('.pd-spec-tab-btn').forEach(function (button) {
            button.addEventListener('click', function () {
                activeSpecCategory = button.dataset.specCategory;
                updateSpecTabActiveState();
                const targetSection = document.getElementById(button.dataset.specTarget);
                if (!targetSection || !specModalContent) return;
                isProgrammaticSpecScroll = true;
                targetSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
                window.setTimeout(function () {
                    isProgrammaticSpecScroll = false;
                }, 450);
            });
        });
    }

    function bindSpecModalScrollSpy() {
        if (!specModalContent) return;

        specModalContent.addEventListener('scroll', function () {
            if (isProgrammaticSpecScroll) return;
            const sections = specModalContent.querySelectorAll('.pd-spec-modal-section');
            if (!sections.length) return;

            const scrollTop = specModalContent.scrollTop + 24;
            let activeSection = sections[0];
            sections.forEach(function (section) {
                if (section.offsetTop <= scrollTop) activeSection = section;
            });

            const categoryFromScroll = activeSection.getAttribute('data-spec-section');
            if (categoryFromScroll && categoryFromScroll !== activeSpecCategory) {
                activeSpecCategory = categoryFromScroll;
                updateSpecTabActiveState();
                const activeTab = specModalTabs ? specModalTabs.querySelector('.pd-spec-tab-btn.is-active') : null;
                if (activeTab) {
                    activeTab.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
                }
            }
        });
    }

    function openSpecModal() {
        if (!specModal) return;
        activeSpecCategory = specCategories[0];
        renderSpecModalContent();
        renderSpecModalTabs();
        if (specModalContent) specModalContent.scrollTop = 0;
        updateSpecTabActiveState();
        specModal.classList.add('is-open');
        specModal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
    }

    function closeSpecModal() {
        if (!specModal) return;
        specModal.classList.remove('is-open');
        specModal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
    }

    bindSpecModalScrollSpy();

    function showMedia(mediaType, url) {
        if (mediaType === 'feature') {
            if (mainVideo) {
                mainVideo.pause();
                mainVideo.classList.add('pd-hidden');
                mainVideo.removeAttribute('src');
                mainVideo.load();
            }
            if (mainImage) {
                mainImage.classList.add('pd-hidden');
                mainImage.removeAttribute('src');
            }
            if (featurePanel) {
                featurePanel.classList.remove('pd-hidden');
            }
            if (stage) {
                stage.classList.add('pd-feature-mode');
            }
            return;
        }

        if (featurePanel) {
            featurePanel.classList.add('pd-hidden');
        }
        if (stage) {
            stage.classList.remove('pd-feature-mode');
        }

        if (mediaType === 'video' && mainVideo) {
            if (mainImage) {
                mainImage.classList.add('pd-hidden');
                mainImage.removeAttribute('src');
                mainImage.style.transform = '';
            }
            mainVideo.classList.remove('pd-hidden');
            mainVideo.src = url;
            mainVideo.load();
            mainVideo.play().catch(() => {});
            return;
        }

        if (mainVideo) {
            mainVideo.pause();
            mainVideo.classList.add('pd-hidden');
            mainVideo.removeAttribute('src');
            mainVideo.load();
        }
        if (mainImage) {
            mainImage.classList.remove('pd-hidden');
            mainImage.src = url;
        }
    }

    thumbButtons.forEach(function (button) {
        button.addEventListener('click', function () {
            thumbButtons.forEach(function (item) { item.classList.remove('is-active'); });
            button.classList.add('is-active');
            showMedia(button.dataset.mediaType, button.dataset.url);
        });
    });

    storageButtons.forEach(function (button) {
        button.addEventListener('click', function () {
            storageButtons.forEach(function (item) { item.classList.remove('is-active'); });
            button.classList.add('is-active');
            state.basePrice = Number(button.dataset.price || 0);
            renderPrice();
        });
    });

    colorButtons.forEach(function (button) {
        button.addEventListener('click', function () {
            colorButtons.forEach(function (item) { item.classList.remove('is-active'); });
            button.classList.add('is-active');
            state.colorDelta = Number(button.dataset.colorPrice || 0);
            if (selectedColorLabel) selectedColorLabel.textContent = button.dataset.colorName || '';
            renderPrice();
        });
    });

    if (stage && mainImage) {
        // Image zoom disabled - display fixed size
    }

    if (specToggleBtn && specModal) {
        specToggleBtn.addEventListener('click', function () {
            openSpecModal();
        });
    }

    if (specModalClose) {
        specModalClose.addEventListener('click', function () {
            closeSpecModal();
        });
    }

    if (specModal) {
        specModal.addEventListener('click', function (event) {
            if (event.target === specModal) closeSpecModal();
        });
    }

    document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape' && specModal && specModal.classList.contains('is-open')) {
            closeSpecModal();
        }
    });

    if (relatedTrack && relatedPrevBtn && relatedNextBtn) {
        relatedPrevBtn.addEventListener('click', function () {
            relatedTrack.scrollBy({ left: -320, behavior: 'smooth' });
        });
        relatedNextBtn.addEventListener('click', function () {
            relatedTrack.scrollBy({ left: 320, behavior: 'smooth' });
        });
    }

    // Media gallery navigation
    const navPrevBtn = document.getElementById('pdPrevBtn');
    const navNextBtn = document.getElementById('pdNextBtn');
    const allMediaButtons = document.querySelectorAll('.pd-media-selector-btn, .pd-feature-selector-btn, .pd-image-thumb');
    let currentMediaIndex = 0;

    if (allMediaButtons.length > 0) {
        // Find initial active media index
        for (let i = 0; i < allMediaButtons.length; i++) {
            if (allMediaButtons[i].classList.contains('is-active')) {
                currentMediaIndex = i;
                break;
            }
        }

        function navigateToMedia(index) {
            if (index < 0) index = allMediaButtons.length - 1;
            if (index >= allMediaButtons.length) index = 0;
            currentMediaIndex = index;
            
            // Click the media button to show it
            allMediaButtons[currentMediaIndex].click();
            
            // Update active state
            allMediaButtons.forEach(btn => btn.classList.remove('is-active'));
            allMediaButtons[currentMediaIndex].classList.add('is-active');
        }

        if (navPrevBtn) {
            navPrevBtn.addEventListener('click', function () {
                navigateToMedia(currentMediaIndex - 1);
            });
        }

        if (navNextBtn) {
            navNextBtn.addEventListener('click', function () {
                navigateToMedia(currentMediaIndex + 1);
            });
        }

        // Update index when thumbnail is clicked
        allMediaButtons.forEach((btn, index) => {
            btn.addEventListener('click', function () {
                currentMediaIndex = index;
            });
        });
    }

    renderPrice();

    document.querySelectorAll('.btn-add-cart').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
            e.preventDefault();
            addToCartAjax(this.dataset.productId, 1);
        });
    });

    document.querySelectorAll('.btn-buy-now').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
            e.preventDefault();
            window.location.href = `{% url 'store:checkout' %}?product_id=${this.dataset.productId}&quantity=1`;
        });
    });

    document.querySelectorAll('.btn-wishlist').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
            e.preventDefault();
            toggleWishlistAjax(this.dataset.productId, this);
        });
    });
});
</script>
{% endblock %}
